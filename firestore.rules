rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Global Core Helper Method: Verifies user has passed basic authentication check
    function isAuthenticated() {
      return request.auth != null;
    }

    // High-Security Architectural Verification: Reads the user record from the database
    // to check if their designated role mapping is explicitly matched to 'admin'.
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 1. USERS COLLECTION PROTECTION MATRIX
    match /users/{userId} {
      allow read, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // 2. PRODUCTS COLLECTION PROTECTION MATRIX
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // CATEGORIES COLLECTION PROTECTION MATRIX
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // BRANDS COLLECTION PROTECTION MATRIX
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // PACKAGES COLLECTION PROTECTION MATRIX
    match /packages/{packageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // HERO SLIDES COLLECTION PROTECTION MATRIX
    match /heroSlides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // PRODUCT ROWS COLLECTION PROTECTION MATRIX
    match /productRows/{rowId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // CATEGORY TILES COLLECTION PROTECTION MATRIX
    match /categoryTiles/{tileId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // SIDE PROMOS COLLECTION PROTECTION MATRIX
    match /sidePromos/{promoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. ORDERS COLLECTION PROTECTION MATRIX
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}